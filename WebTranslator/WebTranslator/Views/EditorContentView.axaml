<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="WebTranslator.Views.EditorContentView"
             x:DataType="vm:EditorContentViewModel"
             xmlns:edit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             xmlns:vm="clr-namespace:WebTranslator.ViewModels"
             xmlns:fa="using:FluentAvalonia.UI.Controls">
    <UserControl.Styles>
        <Style Selector="edit|TextEditor">
            <Setter Property="Margin" Value="{StaticResource TextControlThemePadding}" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="VerticalScrollBarVisibility" Value="Visible" />
            <Setter Property="ShowLineNumbers" Value="True" />
            <Setter Property="WordWrap" Value="True" />
        </Style>
        <Style Selector="Border.FABorder">
            <Setter Property="BorderThickness" Value="{StaticResource TextControlBorderThemeThickness}" />
            <Setter Property="BorderBrush" Value="{StaticResource TextControlBorderBrush}" />
            <Setter Property="CornerRadius" Value="{StaticResource ControlCornerRadius}" />
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="MinHeight" Value="48" />
        </Style>
        <Style Selector="Border.Card">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="CornerRadius" Value="{StaticResource ControlCornerRadius}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="MinHeight" Value="80" />
            <Setter Property="Padding" Value="{StaticResource ContentDialogPadding}" />
            <Setter Property="Margin" Value="{DynamicResource FlyoutContentThemeMargin}" />
        </Style>
        <Style Selector="StackPanel.ShortCut TextBlock">
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="Border.KeyCap">
            <Setter Property="MinWidth" Value="24" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
            <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
        </Style>
        <Style Selector="Border.KeyCap TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="fa|FAPathIcon.ShortcutIcon">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>
        <Style Selector="fa|FAPathIcon.ShortcutIcon.Disabled">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
        </Style>
    </UserControl.Styles>
    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,*" Margin="{DynamicResource FlyoutContentPadding}">
        <fa:CommandBar Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" DefaultLabelPosition="Right" Margin="0,-8,0,8">
            <fa:CommandBar.PrimaryCommands>
                <fa:CommandBarButton Label="暂存更改" ToolTip.Tip="保存所有未保存的更改项"
                                     Command="{Binding SaveAll}">
                    <fa:CommandBarButton.IconSource>
                        <fa:PathIconSource Data="{StaticResource IconSaveAs}" />
                    </fa:CommandBarButton.IconSource>
                </fa:CommandBarButton>
                <fa:CommandBarButton Label="开始导出" ToolTip.Tip="完成翻译，进入导出页"
                                     Command="{Binding ExportCommand}">
                    <fa:CommandBarButton.IconSource>
                        <fa:PathIconSource Data="{StaticResource IconSave}" />
                    </fa:CommandBarButton.IconSource>
                </fa:CommandBarButton>
                <fa:CommandBarSeparator />
                <fa:CommandBarButton Label="清除重复译文" ToolTip.Tip="当译文与原文完全相同时，将译文清空，留待翻译"
                                     Command="{Binding ClearAllTranslationText}">
                    <fa:CommandBarButton.IconSource>
                        <fa:PathIconSource Data="{StaticResource IconDelete}" />
                    </fa:CommandBarButton.IconSource>
                </fa:CommandBarButton>
                <fa:CommandBarButton Label="填充原文到译文" ToolTip.Tip="使用原文填充所有为空的译文"
                                     Command="{Binding FillAllTranslationText}">
                    <fa:CommandBarButton.IconSource>
                        <fa:PathIconSource Data="{StaticResource IconClipboardFilled}" />
                    </fa:CommandBarButton.IconSource>
                </fa:CommandBarButton>
                <fa:CommandBarSeparator />
                <fa:CommandBarToggleButton Label="自动跳转翻译项" ToolTip.Tip="当点击提交时，自动跳转到下一条译文为空的条目"
                                           IsChecked="{Binding AutoSkip}">
                    <fa:CommandBarToggleButton.IconSource>
                        <fa:PathIconSource Data="{StaticResource IconImport}" />
                    </fa:CommandBarToggleButton.IconSource>
                </fa:CommandBarToggleButton>
                <fa:CommandBarToggleButton Label="标记重复译文" ToolTip.Tip="标记译文与原文完全相同的条目"
                                           IsChecked="{Binding MarkSameText}">
                    <fa:CommandBarToggleButton.IconSource>
                        <fa:PathIconSource Data="{StaticResource IconFlag}" />
                    </fa:CommandBarToggleButton.IconSource>
                </fa:CommandBarToggleButton>
            </fa:CommandBar.PrimaryCommands>
            <fa:CommandBar.SecondaryCommands>
                <!-- <fa:CommandBarButton Label="附加功能" /> -->
            </fa:CommandBar.SecondaryCommands>
        </fa:CommandBar>
        <Grid Grid.Row="1" Grid.Column="0" Width="300" Margin="0,0,16,0" RowDefinitions="Auto,Auto,*">
            <TextBox Grid.Row="0" Watermark="搜索键名、原文或译文" Text="{Binding SearchQuery}" />
            <TextBlock Grid.Row="1" Margin="0,6,0,8" FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       IsVisible="{Binding HasSearchQuery}"
                       Text="{Binding SearchResultCount,StringFormat='匹配 {0} 项'}" />
            <ListBox Grid.Row="2" ItemsSource="{Binding EditorList}"
                     SelectedIndex="{Binding SelectedIndex}"
                     SelectedItem="{Binding TranslationItem}"
                     IsVisible="{Binding !HasSearchQuery}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:EditorListItem">
                        <Grid RowDefinitions="*,Auto" ColumnDefinitions="Auto,*,Auto">
                            <fa:FAPathIcon Margin="0,0,8,0" VerticalAlignment="Center"
                                         Foreground="Green" Data="{StaticResource IconCheck}" IsVisible="{Binding IsTranslated}" />
                            <fa:FAPathIcon Grid.Column="0" Grid.Row="0" Margin="0,0,8,0" VerticalAlignment="Center"
                                         Foreground="Red" Data="{StaticResource IconDismiss}" IsVisible="{Binding !IsTranslated}" />
                            <fa:FAPathIcon Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,-8,0"
                                         VerticalAlignment="Center" HorizontalAlignment="Right"
                                         Foreground="Coral" Data="{StaticResource IconDirty}" Width="8" Height="8"
                                         IsVisible="{Binding IsChanged}" />
                            <TextBlock Grid.Column="1" Grid.Row="0" FontSize="16" Text="{Binding OriginalText}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1" Grid.Row="1" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorDisabled}"
                                       Text="{Binding SavedTranslatedText}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="2" Grid.Row="0" Grid.RowSpan="2" Margin="8,0,0,0"
                                       VerticalAlignment="Center" FontSize="11" Foreground="Brown"
                                       IsVisible="{Binding IsSameTextMarked}">重复</TextBlock>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <ListBox Grid.Row="2" ItemsSource="{Binding SearchResults}"
                     SelectedItem="{Binding SelectedSearchItem}"
                     IsVisible="{Binding HasSearchQuery}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:EditorListItem">
                        <Grid RowDefinitions="*,Auto" ColumnDefinitions="Auto,*">
                            <fa:FAPathIcon Margin="0,0,8,0" VerticalAlignment="Center"
                                         Foreground="Green" Data="{StaticResource IconCheck}" IsVisible="{Binding IsTranslated}" />
                            <fa:FAPathIcon Grid.Column="0" Grid.Row="0" Margin="0,0,8,0" VerticalAlignment="Center"
                                         Foreground="Red" Data="{StaticResource IconDismiss}" IsVisible="{Binding !IsTranslated}" />
                            <TextBlock Grid.Column="1" Grid.Row="0" FontSize="16" Text="{Binding OriginalText}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1" Grid.Row="1" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorDisabled}"
                                       Text="{Binding SavedTranslatedText}"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
        <Grid Grid.Row="1" Grid.Column="1" RowDefinitions="Auto,*,Auto,Auto">
            <StackPanel Grid.Row="0">
                <TextBlock Text="{Binding Header,StringFormat='模组路径: {0}',Mode=OneTime}" FontSize="16" />
                <Grid>
                    <TextBlock Text="{Binding TranslationItem.Key,StringFormat='键名: {0}',Mode=OneWay}" />
                    <TextBlock HorizontalAlignment="Right">
                        <Run Text="翻译进度 " />
                        <Run Text="{Binding TranslatedCount}" />
                        <Run Text="|" />
                        <Run Text="{Binding AllCount}" />
                    </TextBlock>
                </Grid>
            </StackPanel>
            <Grid Grid.Row="1" RowDefinitions="*,*" Margin="0,12,0,0">
                <Border Classes="Card" Grid.Row="0">
                    <Grid RowDefinitions="Auto,Auto,*">
                        <TextBlock Grid.Row="0" Text="原文" />
                        <Separator Grid.Row="1"
                                   Foreground="{DynamicResource ScrollViewerScrollBarsSeparatorBackground}"
                                   HorizontalAlignment="Stretch"
                                   Height="{DynamicResource MenuFlyoutSeparatorThemeHeight}"
                                   Padding="{StaticResource MenuFlyoutSeparatorThemePadding}" />
                        <edit:TextEditor
                            Grid.Row="2"
                            IsReadOnly="True"
                            Document="{Binding TranslationItem.OriginalDoc}"
                            Loaded="SyntaxEditorLoaded"
                            ShowLineNumbers="True"
                            Name="SyntaxEditor1">
                            <edit:TextEditor.ContextFlyout>
                                <MenuFlyout>
                                    <MenuItem Header="Copy" InputGesture="Ctrl+C"
                                              Command="{Binding ElementName=SyntaxEditor1, Path=Copy}">
                                        <MenuItem.Icon>
                                            <fa:FAPathIcon Data="{StaticResource IconCopy}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </MenuFlyout>
                            </edit:TextEditor.ContextFlyout>
                        </edit:TextEditor>
                    </Grid>
                </Border>
                <Border Classes="Card" Grid.Row="1" Margin="0,12,0,0">
                    <Grid RowDefinitions="Auto,Auto,*">
                        <TextBlock Grid.Row="0" Text="译文" />
                        <Separator Grid.Row="1"
                                   Foreground="{DynamicResource ScrollViewerScrollBarsSeparatorBackground}"
                                   HorizontalAlignment="Stretch"
                                   Height="{DynamicResource MenuFlyoutSeparatorThemeHeight}"
                                   Padding="{StaticResource MenuFlyoutSeparatorThemePadding}" />
                        <edit:TextEditor
                            Grid.Row="2"
                            Document="{Binding TranslationItem.TranslatedDoc}"
                            Loaded="SyntaxEditorLoaded"
                            ShowLineNumbers="True"
                            Name="SyntaxEditor2">
                            <edit:TextEditor.ContextFlyout>
                                <MenuFlyout>
                                    <MenuItem Header="Cut" InputGesture="Ctrl+X"
                                              Command="{Binding ElementName=SyntaxEditor2, Path=Cut}">
                                        <MenuItem.Icon>
                                            <fa:FAPathIcon Data="{StaticResource IconCut}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Copy" InputGesture="Ctrl+C"
                                              Command="{Binding ElementName=SyntaxEditor2, Path=Copy}">
                                        <MenuItem.Icon>
                                            <fa:FAPathIcon Data="{StaticResource IconCopy}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Paste" InputGesture="Ctrl+V"
                                              Command="{Binding ElementName=SyntaxEditor2, Path=Paste}">
                                        <MenuItem.Icon>
                                            <fa:FAPathIcon Data="{StaticResource IconPaste}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </MenuFlyout>
                            </edit:TextEditor.ContextFlyout>
                        </edit:TextEditor>
                    </Grid>
                </Border>
            </Grid>
            <StackPanel Grid.Row="2" Spacing="6" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,12,0,0">
                <Button Command="{Binding PrevItem}">上一个</Button>
                <Button Command="{Binding NextItem}">下一个</Button>
                <Button
                    IsEnabled="{Binding TranslationItem.IsChanged}"
                    Command="{Binding TranslationItem.Reset}">
                    重置
                </Button>
            </StackPanel>
            <StackPanel Grid.Row="2" Spacing="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Command="{Binding SkipItem}">
                    跳过
                </Button>
                <Button IsEnabled="{Binding TranslationItem.IsChanged}" Command="{Binding SaveItem}">
                    保存
                </Button>
                <!-- ReSharper disable once Xaml.StyleClassNotFound -->
                <Button IsEnabled="{Binding TranslationItem.IsChanged}" Classes="accent"
                        Command="{Binding SubmitItem}"
                        ToolTip.Tip="保存并跳转到下一个带翻译条目">
                    提交
                </Button>
            </StackPanel>
            <StackPanel Grid.Row="2" IsVisible="False"
                        Spacing="6" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                <Button HotKey="Ctrl+S" Command="{Binding SaveAll}">暂存快捷键</Button>
                <Button HotKey="Ctrl+Shift+C" Command="{Binding TranslationItem.Clear}">清空快捷键</Button>
                <Button HotKey="Ctrl+Shift+N" Command="{Binding NextItem}">下一个快捷键</Button>
                <Button HotKey="Ctrl+Shift+B" Command="{Binding PrevItem}">上一个快捷键</Button>
                <Button HotKey="Ctrl+N" Command="{Binding SkipItem}">跳过快捷键</Button>
            </StackPanel>
            <Grid Grid.Row="3" MinHeight="250" Margin="0,12,0,0">
                <StackPanel Spacing="8">
                    <TextBlock FontWeight="SemiBold">词典推荐</TextBlock>
                    <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               IsVisible="{Binding !HasSuggestions}">当前条目没有可用推荐</TextBlock>
                    <ItemsControl ItemsSource="{Binding Suggestions}" IsVisible="{Binding HasSuggestions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:TranslationSuggestion">
                                <Button Margin="0,0,8,8" Command="{Binding Apply}" ToolTip.Tip="{Binding ShortcutText}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Border Classes="KeyCap">
                                            <TextBlock Text="{Binding ShortcutNumber}" />
                                        </Border>
                                        <fa:FAPathIcon Data="{StaticResource IconBook}" />
                                        <TextBlock Text="{Binding Text}" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </Grid>
        <Border Grid.Row="1" MinWidth="200" Grid.Column="2" VerticalAlignment="Stretch" Margin="16,0,0,0">
            <Grid>
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding TranslationItem.OriginalLineCount,StringFormat='原文行数: {0}'}" />
                    <TextBlock Text="{Binding TranslationItem.TranslatedLineCount,StringFormat='译文行数: {0}'}" />

                    <Separator Height="0" Opacity="0" />

                    <TextBlock IsVisible="{Binding TranslationItem.FormatError}">格式化字符串与原文不匹配</TextBlock>
                </StackPanel>
                <StackPanel Spacing="6" VerticalAlignment="Bottom" Classes="ShortCut">
                    <Separator Height="0" Opacity="0" />
                    <Grid ColumnDefinitions="Auto,*" ToolTip.Tip="暂存所有结果">
                        <fa:FAPathIcon Classes="ShortcutIcon" Data="{StaticResource IconSaveAs}" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                            <Border Classes="KeyCap">
                                <TextBlock Text="{Binding CommandModifierText}" />
                            </Border>
                            <Border Classes="KeyCap">
                                <TextBlock Text="S" />
                            </Border>
                        </StackPanel>
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ToolTip.Tip="清空当前译文">
                        <fa:FAPathIcon Classes="ShortcutIcon" Data="{StaticResource IconDelete}" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                            <Border Classes="KeyCap">
                                <TextBlock Text="{Binding CommandShiftModifierText}" />
                            </Border>
                            <Border Classes="KeyCap">
                                <TextBlock Text="C" />
                            </Border>
                        </StackPanel>
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ToolTip.Tip="上一个">
                        <fa:FAPathIcon Classes="ShortcutIcon" Data="{StaticResource IconImport}">
                            <fa:FAPathIcon.RenderTransform>
                                <RotateTransform Angle="180" />
                            </fa:FAPathIcon.RenderTransform>
                        </fa:FAPathIcon>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                            <Border Classes="KeyCap">
                                <TextBlock Text="{Binding CommandShiftModifierText}" />
                            </Border>
                            <Border Classes="KeyCap">
                                <TextBlock Text="B" />
                            </Border>
                        </StackPanel>
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ToolTip.Tip="下一个">
                        <fa:FAPathIcon Classes="ShortcutIcon" Data="{StaticResource IconImport}" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                            <Border Classes="KeyCap">
                                <TextBlock Text="{Binding CommandShiftModifierText}" />
                            </Border>
                            <Border Classes="KeyCap">
                                <TextBlock Text="N" />
                            </Border>
                        </StackPanel>
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ToolTip.Tip="跳过">
                        <fa:FAPathIcon Classes="ShortcutIcon" Data="{StaticResource IconCheckCircle}" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                            <Border Classes="KeyCap">
                                <TextBlock Text="{Binding CommandModifierText}" />
                            </Border>
                            <Border Classes="KeyCap">
                                <TextBlock Text="N" />
                            </Border>
                        </StackPanel>
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ToolTip.Tip="Enter 换行或提交">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <fa:FAPathIcon Classes="ShortcutIcon Disabled" Data="{StaticResource IconLines}"
                                           IsVisible="{Binding TranslationItem.EqualLines}" />
                            <fa:FAPathIcon Classes="ShortcutIcon" Data="{StaticResource IconLines}"
                                           IsVisible="{Binding !TranslationItem.EqualLines}" />
                            <fa:FAPathIcon Classes="ShortcutIcon" Data="{StaticResource IconCheckCircle}"
                                           IsVisible="{Binding TranslationItem.EqualLines}" />
                            <fa:FAPathIcon Classes="ShortcutIcon Disabled" Data="{StaticResource IconCheckCircle}"
                                           IsVisible="{Binding !TranslationItem.EqualLines}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                            <Border Classes="KeyCap">
                                <TextBlock Text="Enter" />
                            </Border>
                        </StackPanel>
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ToolTip.Tip="应用词典推荐">
                        <fa:FAPathIcon Classes="ShortcutIcon" Data="{StaticResource IconBook}" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                            <Border Classes="KeyCap">
                                <TextBlock Text="{Binding SuggestionShortcutModifierText}" />
                            </Border>
                            <Border Classes="KeyCap">
                                <TextBlock Text="1-9" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
