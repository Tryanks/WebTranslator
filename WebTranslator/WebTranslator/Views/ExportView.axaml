<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
             x:DataType="vm:ExportViewModel"
             x:Class="WebTranslator.Views.ExportView"
             xmlns:vm="clr-namespace:WebTranslator.ViewModels"
             xmlns:edit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             xmlns:ic="using:FluentIcons.Avalonia.Fluent">
    <UserControl.Styles>
        <Style Selector="edit|TextEditor">
            <Setter Property="Margin" Value="{StaticResource TextControlThemePadding}" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="VerticalScrollBarVisibility" Value="Visible" />
            <Setter Property="ShowLineNumbers" Value="True" />
            <Setter Property="WordWrap" Value="True" />
        </Style>
        <Style Selector="Border.Card">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="CornerRadius" Value="{StaticResource ControlCornerRadius}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="MinHeight" Value="80" />
            <Setter Property="Padding" Value="{StaticResource ContentDialogPadding}" />
            <Setter Property="Margin" Value="{DynamicResource FlyoutContentThemeMargin}" />
        </Style>
    </UserControl.Styles>

    <Grid Margin="{DynamicResource FlyoutContentPadding}" RowDefinitions="Auto,*,Auto">
        <fa:CommandBar Grid.Row="0" DefaultLabelPosition="Right" Margin="0,-8,0,8">
            <fa:CommandBar.PrimaryCommands>
                <fa:CommandBarButton IconSource="Copy" Label="复制到剪贴板" Command="{Binding CopyCommand}"/>
                <fa:CommandBarButton IconSource="Save" Label="另存为" Command="{Binding SaveAsCommand}"/>
                <fa:CommandBarButton IconSource="Save" Label="保存到原文件" Command="{Binding SaveToOriginCommand}"
                                     IsEnabled="{Binding CanSaveToOrigin}"/>
            </fa:CommandBar.PrimaryCommands>
            <fa:CommandBar.SecondaryCommands>
                <fa:CommandBarButton IconSource="ClipboardLink" Label="复制文件名" Command="{Binding CopyFileNameCommand}" />
            </fa:CommandBar.SecondaryCommands>
        </fa:CommandBar>

        <Grid Grid.Row="1" RowDefinitions="Auto,*,Auto" ColumnDefinitions="*,320">
            <Border Classes="Card" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto" RowDefinitions="Auto">
                    <StackPanel Spacing="4">
                        <TextBlock Text="导出文件" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock FontWeight="SemiBold" Text="{Binding FileName}"/>
                            <TextBlock Text="{Binding FormatName,StringFormat='格式: {0}'}"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="24,0,0,0">
                        <ic:SymbolIcon Symbol="Clipboard"/>
                        <TextBlock Text="{Binding TextLength,StringFormat='字符数 {0}'}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" Margin="24,0,0,0">
                        <ic:SymbolIcon Symbol="TextBulletListSquare"/>
                        <TextBlock Text="{Binding LineCount,StringFormat='行数 {0}'}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" Margin="24,0,0,0">
                        <ic:SymbolIcon Symbol="BranchFork"/>
                        <TextBlock IsVisible="{Binding HasDiff}" Text="存在变更"/>
                        <TextBlock IsVisible="{Binding !HasDiff}" Text="无待保存差异"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Classes="Card" Grid.Row="1" Grid.Column="0">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="文件预览" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <edit:TextEditor Grid.Row="1" Name="Editor" IsReadOnly="True" Document="{Binding Document}">
                        <edit:TextEditor.ContextFlyout>
                            <MenuFlyout>
                                <MenuItem Header="Copy" InputGesture="Ctrl+C" Command="{Binding ElementName=Editor, Path=Copy}">
                                    <MenuItem.Icon>
                                        <ic:SymbolIcon Symbol="Copy" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </MenuFlyout>
                        </edit:TextEditor.ContextFlyout>
                    </edit:TextEditor>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Grid.Column="1">
                <Border Classes="Card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="保存目标" FontWeight="SemiBold"/>
                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="{Binding SaveTargetText}"/>
                        <CheckBox Content="进入导出页时自动保存到原文件夹"
                                  IsChecked="{Binding AutoSaveToOrigin}"
                                  IsVisible="{Binding IsLocalFolder}"/>
                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   IsVisible="{Binding !IsLocalFolder}"
                                   Text="当前导入来源不能直接写回原文件。"/>
                    </StackPanel>
                </Border>
                <Border Classes="Card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="最近保存" FontWeight="SemiBold"/>
                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="{Binding LastSavedPath}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Classes="Card" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" IsVisible="{Binding HasDiff}">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="差异预览" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <edit:TextEditor Grid.Row="1" Name="DiffEditor" IsReadOnly="True" Document="{Binding DiffDocument}">
                        <edit:TextEditor.ContextFlyout>
                            <MenuFlyout>
                                <MenuItem Header="Copy" InputGesture="Ctrl+C" Command="{Binding ElementName=DiffEditor, Path=Copy}">
                                    <MenuItem.Icon>
                                        <ic:SymbolIcon Symbol="Copy" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </MenuFlyout>
                        </edit:TextEditor.ContextFlyout>
                    </edit:TextEditor>
                </Grid>
            </Border>

            <Border Classes="Card" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" IsVisible="{Binding !HasDiff}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <ic:SymbolIcon Symbol="CheckmarkCircle"/>
                    <TextBlock Text="当前导出内容与原文件一致，或尚未关联可比较的原文件。"/>
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2" HorizontalAlignment="Right" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Text="导出完成后可提交到项目或发布 PR"/>
    </Grid>
</UserControl>
